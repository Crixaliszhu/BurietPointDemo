<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/white"
    android:orientation="horizontal">

    <!-- 找工作 Tab -->
    <LinearLayout
        android:id="@+id/tabFindWork"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivTabFindWork"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="5dp"
            android:contentDescription="@string/tab_find_work"
            android:src="@drawable/selector_tab_find_work" />

        <TextView
            android:id="@+id/tvTabFindWork"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_find_work"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 求职顾问 Tab -->
    <LinearLayout
        android:id="@+id/tabJobHelper"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivTabJobHelper"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="5dp"
            android:contentDescription="@string/tab_job_helper"
            android:src="@drawable/selector_tab_job_helper" />

        <TextView
            android:id="@+id/tvTabJobHelper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_job_helper"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 消息 Tab -->
    <LinearLayout
        android:id="@+id/tabMessage"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivTabMessage"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="5dp"
            android:contentDescription="@string/tab_message"
            android:src="@drawable/selector_tab_message" />

        <TextView
            android:id="@+id/tvTabMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_message"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 我的 Tab -->
    <LinearLayout
        android:id="@+id/tabMine"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivTabMine"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="5dp"
            android:contentDescription="@string/tab_mine"
            android:src="@drawable/selector_tab_mine" />

        <TextView
            android:id="@+id/tvTabMine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/tab_mine"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
